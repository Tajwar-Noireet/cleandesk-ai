PORT=5000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
AI_SERVICE_URL=http://localhost:8000

# AI receptionist behaviour
# Set to 'false' to disable all AI auto-replies (useful for testing or manual-only mode)
AUTO_AI_REPLY_ON_ENQUIRY=true
# Maximum consecutive AI auto-replies before handing off to human review (default: 2)
AI_MAX_CONSECUTIVE_REPLIES=2
